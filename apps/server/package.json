    "@forgewright/autopilot": "workspace:*",
    "@forgewright/context": "workspace:*",
    "@forgewright/documents": "workspace:*",
    "@forgewright/git": "workspace:*",
    "@forgewright/google": "workspace:*",
    "@forgewright/integrations": "workspace:*",
    "@forgewright/jobs": "workspace:*",
    "@forgewright/llm": "workspace:*",
    "@forgewright/mcp": "workspace:*",
    "@forgewright/memory": "workspace:*",
    "@forgewright/oauth": "workspace:*",
    "@forgewright/orchestrator": "workspace:*",
    "@forgewright/planner": "workspace:*",
    "@forgewright/shared": "workspace:*",
    "@forgewright/tools": "workspace:*",
    "@forgewright/types": "workspace:*",
    "fastify": "^5.2.0"
  }
}
