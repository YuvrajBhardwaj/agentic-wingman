{
  "name": "@forgewright/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forgewright/agent": "*",
    "@forgewright/context": "*",
    "@forgewright/git": "*",
    "@forgewright/llm": "*",
    "@forgewright/memory": "*",
    "@forgewright/shared": "*",
    "@forgewright/tools": "*",
    "@forgewright/types": "*"
  }
}
