# Forgewright configuration. Copy to .env and adjust.
# Local mode needs ZERO config — these are all optional overrides.

# Runtime
# FORGE_MODE=local              # local | scaled
# FORGE_WORKSPACE=.             # repo to operate on (defaults to cwd)
# FORGE_DATA_DIR=~/.forgewright     # where Forgewright stores db/index/caches
# FORGE_LOG_LEVEL=info          # debug | info | warn | error

# Server
# FORGE_HOST=127.0.0.1
# FORGE_PORT=4317

# LLM endpoint (OpenAI-compatible or Ollama). Works with LM Studio, DeepSeek,
# Qwen Coder, Ollama, Groq, NVIDIA NIM, or any OpenAI-compatible server.
# FORGE_LLM_KIND=openai-compatible   # openai-compatible | ollama
# FORGE_LLM_BASE_URL=http://localhost:11434/v1
# FORGE_LLM_MODEL=qwen2.5-coder
# FORGE_LLM_API_KEY=                 # only if your endpoint requires one
#
# --- Groq Cloud (https://console.groq.com) ---
# FORGE_LLM_KIND=openai-compatible
# FORGE_LLM_BASE_URL=https://api.groq.com/openai/v1
# FORGE_LLM_MODEL=llama-3.3-70b-versatile   # pick a tool-calling model
# FORGE_LLM_API_KEY=gsk_xxxxxxxxxxxxxxxx
#
# --- NVIDIA NIM (https://build.nvidia.com) ---
# FORGE_LLM_KIND=openai-compatible
# FORGE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# FORGE_LLM_MODEL=meta/llama-3.3-70b-instruct   # or qwen/qwen2.5-coder-32b-instruct
# FORGE_LLM_API_KEY=nvapi-xxxxxxxxxxxxxxxx
#
# NOTE: embeddings stay LOCAL by default (FORGE_EMBED_PROVIDER=local, offline
# hashing) — neither Groq nor the wired embedder calls a cloud embeddings API,
# so memory/PKB work with no extra config. Only the chat LLM goes to the cloud.

# Model routing (each role -> an endpoint id; defaults to "default")
# FORGE_ROUTE_CHEAP=default
# FORGE_ROUTE_CODING=default
# FORGE_ROUTE_REASONING=default
# FORGE_ROUTE_VERIFICATION=default

# Embeddings
# FORGE_EMBED_PROVIDER=local         # local | ollama | openai
# FORGE_EMBED_MODEL=BAAI/bge-small-en-v1.5
# FORGE_EMBED_DIMS=384

# Autopilot: shell command that defines "verified" (tests/lint/build)
# FORGE_VERIFY_CMD=pnpm test

# MCP servers to connect (JSON array). Each tool appears as mcp__<name>__<tool>.
# trust: allow | prompt | deny (default prompt).
# FORGE_MCP_SERVERS=[{"name":"github","command":"npx","args":["-y","@modelcontextprotocol/server-github"],"trust":"prompt"}]

# Integrations (register automatically when set; used by /integrations/:id/send)
# FORGE_TELEGRAM_TOKEN=123456:abcdef   # from @BotFather; enables send + inbound polling
# FORGE_SLACK_TOKEN=xoxb-...
# FORGE_WEBHOOK_URL=https://hooks.example.com/incoming
#
# WhatsApp Business Cloud API (Meta). Outbound + inbound via webhook
# (GET/POST /integrations/webhooks/whatsapp).
# FORGE_WHATSAPP_PHONE_ID=1234567890
# FORGE_WHATSAPP_TOKEN=EAAG...           # permanent access token
# FORGE_WHATSAPP_VERIFY_TOKEN=my-verify-secret

# --- Per-user OAuth connectors -------------------------------------------------
# Each connector shows a "Connect" button in the UI once its CLIENT_ID + SECRET
# are set. Users connect their OWN account; tokens are encrypted with
# FORGE_SECRET_KEY. Add <FORGE_PUBLIC_URL>/auth/<provider>/callback as an
# authorized redirect URI in each provider's console.
# FORGE_SECRET_KEY=<64-hex-chars>      # openssl rand -hex 32  (encrypts user tokens at rest)
# FORGE_PUBLIC_URL=https://your-host   # public base URL for OAuth callbacks
# FORGE_WEB_URL=https://your-app       # UI to redirect to after connect (#session=...)
#
# Google (Gmail + Calendar) — also powers the per-user agenda at /me/google/agenda
# FORGE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# FORGE_GOOGLE_CLIENT_SECRET=...
# GitHub (https://github.com/settings/developers)
# FORGE_GITHUB_CLIENT_ID=...
# FORGE_GITHUB_CLIENT_SECRET=...
# Slack (https://api.slack.com/apps — uses Sign in with Slack / OpenID Connect)
# FORGE_SLACK_CLIENT_ID=...
# FORGE_SLACK_CLIENT_SECRET=...
# Discord (https://discord.com/developers/applications)
# FORGE_DISCORD_CLIENT_ID=...
# FORGE_DISCORD_CLIENT_SECRET=...
# Microsoft (Azure AD app registration — Outlook / Microsoft 365)
# FORGE_MICROSOFT_CLIENT_ID=...
# FORGE_MICROSOFT_CLIENT_SECRET=...
#
# Single-account Google refresh token (optional, non-multi-tenant fallback):
# FORGE_GOOGLE_REFRESH_TOKEN=...

# Scaled mode (optional)
# FORGE_DB_URL=postgres://user:pass@localhost:5432/forgewright
# FORGE_VECTOR_URL=http://localhost:6333
